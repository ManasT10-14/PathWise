# Pathwise FastAPI backend — environment configuration template
# Copy this file to .env and fill in the values before running locally.
# NEVER commit .env to version control.

# --- Google Cloud / Vertex AI ---
# Your GCP project ID (find in Cloud Console -> Project selector)
GCP_PROJECT_ID=pathwise-aedc5

# Vertex AI region — us-central1 has best Gemini 2.5 Flash availability
GCP_LOCATION=us-central1

# Gemini model to use for the prompt chain
GEMINI_MODEL=gemini-2.5-flash

# --- Firebase Admin SDK ---
# Path to the service account JSON key file downloaded from:
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Leave empty to use GOOGLE_APPLICATION_CREDENTIALS (Application Default Credentials)
FIREBASE_SERVICE_ACCOUNT=

# --- Razorpay ---
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from Razorpay Dashboard -> Webhooks
RAZORPAY_WEBHOOK_SECRET=

# --- CORS ---
# Comma-separated list of allowed origins (JSON array format)
# Set to ["*"] for development, restrict in production
CORS_ORIGINS=["http://localhost:3000"]

# --- Rate limiting ---
# Max AI analysis requests per user per day
RATE_LIMIT_ANALYSES=10/day
# Max replan requests per user per day
RATE_LIMIT_REPLANS=3/day

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
